# Hoist Metro/Babel transformer deps to the workspace-root node_modules so they
# resolve under pnpm's strict, symlinked layout on the EAS build worker. NativeWind's
# Metro transformer wraps the upstream transformer and requires react-native-css-interop
# + babel plugins that aren't in its own dependency closure; without hoisting these,
# the EAS "Bundle React Native code and images" phase fails with
# "Cannot read properties of undefined (reading 'transformFile')".
# Local `expo export:embed` works because the local install layout differs — this only
# bites on the worker. See apps/mobile. Surgical alternative to node-linker=hoisted.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*nativewind*
public-hoist-pattern[]=*react-native-css-interop*
public-hoist-pattern[]=@babel/*
public-hoist-pattern[]=*metro*
